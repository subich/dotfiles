#!/usr/bin/env bash

set -euo pipefail

for command_name in fzf tmux zoxide; do
  if ! command -v "${command_name}" >/dev/null 2>&1; then
    printf 'tmux project switcher requires %s\n' "${command_name}" >&2
    exit 1
  fi
done

if [[ -z "${TMUX:-}" ]]; then
  printf 'tmux project switcher must run inside tmux\n' >&2
  exit 1
fi

list_candidates() {
  tmux list-windows \
    -F $'window\t[window] #{window_index}: #{window_name} — #{pane_current_path}\t#{window_id}'

  while IFS= read -r directory; do
    [[ -d "${directory}" ]] || continue
    printf 'project\t[project] %s — %s\t%s\n' \
      "${directory##*/}" "${directory}" "${directory}"
  done < <(zoxide query --list 2>/dev/null)
}

selection="$(
  list_candidates | fzf \
    --border=none \
    --cycle \
    --delimiter=$'\t' \
    --height=100% \
    --no-multi \
    --prompt='project> ' \
    --with-nth=2
)" || exit 0

[[ -n "${selection}" ]] || exit 0
IFS=$'\t' read -r candidate_type _ target <<<"${selection}"

if [[ "${candidate_type}" == "window" ]]; then
  tmux select-window -t "${target}"
  exit 0
fi

while IFS=$'\t' read -r window_id pane_id pane_path; do
  if [[ "${pane_path}" == "${target}" ]]; then
    tmux select-window -t "${window_id}"
    tmux select-pane -t "${pane_id}"
    exit 0
  fi
done < <(tmux list-panes -s -F $'#{window_id}\t#{pane_id}\t#{pane_current_path}')

window_name="${target##*/}"
window_name="${window_name//:/-}"
tmux new-window -n "${window_name}" -c "${target}"
