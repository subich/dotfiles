[user]
  email = {{ .email | quote }}
  name = Stefan Subich
  {{- if .gpg_signingkey }}
  signingkey = {{ .gpg_signingkey | quote }}
  {{- end }}

[include]
  path = ~/.config/git/aliases
  path = ~/.config/delta/themes.gitconfig

[core]
  excludesfile = ~/.config/git/ignore
  pager = delta

[credential]
  helper = osxkeychain

[interactive]
  diffFilter = delta --color-only

[delta]
  features = mellow-barbet
  navigate = true
  line-numbers = true
  line-numbers-left-style = brightblack
  line-numbers-right-style = brightblack
  line-numbers-minus-style = brightred
  line-numbers-plus-style = brightgreen
  line-numbers-zero-style = brightblack
  side-by-side = false
  syntax-theme = Dracula
  hunk-header-style = syntax
  plus-style = "syntax #2D3E3F"
  minus-style = "syntax #3D313B"

[merge]
  tool = nvimdiff
  conflictstyle = zdiff3

[mergetool "vimdiff"]
  cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED \
        -c '$wincmd w' -c 'wincmd J'

[diff]
  tool = vimdiff
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true

[color]
  ui = true

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "diff"]
  meta = 11
  frag = magenta bold
  func = 146 bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[init]
  defaultBranch = main

[fetch]
  prune = true
  pruneTags = true
  all = true

[push]
  default = current
  autoSetupRemote = true
  followTags = true

[branch]
  sort = -committerdate

[column]
  ui = auto

[tag]
  sort = version:refname

[help]
  autocorrect = prompt

[commit]
  {{- if .gpg_signingkey }}
  gpgsign = true
  {{- end }}
  verbose = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[url "git@github.com:"]
	insteadOf = https://github.com/
